      {
        "icon": "Paintbrush",
        "title": "Themeable",
        "description": "Customize with Tailwind CSS and DaisyUI for beautiful documentation.",
        "link": "#"
      },
      {
        "icon": "Search",
        "title": "Full-Text Search",
        "description": "Built-in search for easy content discovery.",
        "link": "#"
      }
    ]
