{
  "name": "@docubook/flame",
  "version": "1.3.1",
  "description": "A blazing-fast React + MDX framework powered by Bun, built for modern documentation experiences.",
  "type": "module",
  "bin": {
    "flame": "./bin/cli.js"
  },
  "files": [
    "bin",
    "template",
    "docu.schema.json",
    ".docu",
    "!.docu/__tests__",
    "!.docu/dist",
    "!.docu/build-cache.json",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "engines": {
    "bun": ">=1.1.0"
  },
  "scripts": {
    "dev": "bun .docu/node/server.ts",
    "build": "NODE_ENV=production bun .docu/node/build.ts",
    "clean": "bun .docu/node/clean.ts",
    "preview": "bun .docu/node/preview.ts",
    "deploy": "bun .docu/node/deploy.ts",
    "test": "vitest run",
    "lint": "eslint .",
    "prepublishOnly": "bun .docu/node/clean.ts && eslint . && vitest run"
  },
  "keywords": [
    "docubook",
    "documentation",
    "static-site",
    "daisyui",
    "bun",
    "docs framework",
    "react",
    "react-dom"
  ],
  "homepage": "https://github.com/DocuBook/docubook/tree/main/packages/flame",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DocuBook/docubook.git",
    "directory": "packages/flame"
  },
  "author": "wildan.nrs",
  "author-url": "https://wildan.dev",
  "license": "MIT",
  "dependencies": {
    "@docubook/core": "workspace:^",
    "@docubook/mdx-content": "workspace:^",
    "@docubook/themes-colors": "workspace:^",
    "@docubook/ui-react": "workspace:^",
    "@tailwindcss/cli": "4.3.0",
    "@tailwindcss/typography": "0.5.16",
    "bun-plugin-tailwind": "^0.1.2",
    "daisyui": "^5.5.19",
    "lucide-react": "^1.14.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "peerDependencies": {
    "@sentry/bun": "^10.0.0"
  },
  "peerDependenciesMeta": {
    "@sentry/bun": {
      "optional": true
    }
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.0",
    "bun-types": "^1.3.0",
    "eslint": "^10.3.0",
    "eslint-plugin-perfectionist": "^5.9.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "postcss": "^8.4.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.2"
  }
}
