{
  "$schema": "https://cdn.jsdelivr.net/npm/@docubook/flame/docu.schema.json",
  "meta": {
    "title": "Flame - Docs Framework",
    "description": "A blazing-fast React + MDX framework powered by Bun, built for modern documentation experiences.",
    "baseURL": "https://docubook.pro",
    "favicon": "/docs/assets/images/favicon.ico"
  },
  "sidebar": {
    "context": "separator"
  },
  "themes": {
    "colors": "default"
  },
  "home": {
    "hero": {
      "tagline": "Runtime-agnostic · React + MDX",
      "headline": "Fast as Flame 🔥",
      "description": "The docs framework that runs on Bun, Node.js, and Deno. Powered by Bun's blazing-fast toolchain — generating pure static docs you can deploy anywhere.",
      "actions": [
        {
          "text": "Get Started",
          "link": "/docs/getting-started/introduction",
          "theme": "primary"
        },
        {
          "text": "GitHub",
          "link": "https://github.com/DocuBook/docubook",
          "theme": "ghost",
          "icon": "github"
        }
      ]
    },
    "features": [
      {
        "icon": "Zap",
        "title": "Lightning Fast",
        "description": "Powered by Bun for instant builds and hot module replacement.",
        "link": "/docs"
      },
      {
        "icon": "Paintbrush",
        "title": "Themeable",
        "description": "Customize with Tailwind CSS and DaisyUI for beautiful documentation.",
        "link": "/docs/getting-started/themes"
      },
      {
        "icon": "Search",
        "title": "Full-Text Search",
        "description": "Built-in search with Algolia integration for easy content discovery.",
        "link": "/docs/getting-started/search"
      }
    ]
  },
  "navbar": {
    "logo": {
      "src": "/docs/assets/images/docu.svg",
      "alt": "DocuBook"
    },
    "logoText": "DocuBook",
    "menu": [
      {
        "title": "Home",
        "href": "/"
      },
      {
        "title": "Docs",
        "href": "/docs"
      }
    ]
  },
  "footer": {
    "social": [
      {
        "name": "facebook",
        "url": "https://www.facebook.com/wildan.nrsh"
      },
      {
        "name": "instagram",
        "url": "https://www.instagram.com/wildan.nrs/"
      },
      {
        "name": "npm",
        "url": "https://www.npmjs.com/~wildan.nrs"
      },
      {
        "name": "youtube",
        "url": "https://youtube.com/@wildandotdev"
      },
      {
        "name": "x",
        "url": "https://x.com/wildan_nrss"
      },
      {
        "name": "threads",
        "url": "https://www.threads.com/@wildan.nrs"
      }
    ]
  },
  "repo": {
    "url": "https://github.com/DocuBook/docubook",
    "path": "blob/main/packages/flame/{filePath}",
    "edit": true
  },
