{
  "$schema": "https://docubook.pro/docu.schema.json",
  "meta": {
    "title": "DocuBook Flame",
    "description": "A blazing-fast React + MDX framework powered by Bun, built for modern documentation experiences.",
    "baseURL": "https://docubook.pro",
    "favicon": "/docs/assets/images/favicon.ico"
  },
  "navbar": {
    "logo": {
      "src": "/docs/assets/images/docu.svg",
      "alt": "DocuBook"
    },
    "logoText": "DocuBook",
    "menu": [
      {
        "title": "Home",
        "href": "/"
      },
      {
        "title": "Docs",
        "href": "/docs"
      },
      {
        "title": "Showcase",
        "href": "https://www.docubook.pro/showcase"
      }
    ]
  },
  "footer": {
    "social": [
      {
        "name": "gitHub",
        "url": "https://github.com/DocuBook/docubook"
      },
      {
        "name": "npm",
        "url": "https://www.npmjs.com/~wildan.nrs"
      },
      {
        "name": "youtube",
        "url": "https://youtube.com/@wildandotdev"
      }
    ]
  },
  "repo": {
    "url": "https://github.com/DocuBook/docubook",
    "path": "blob/main/apps/web/{filePath}",
    "edit": true
  },
  "routes": [
    {
      "title": "Getting Started",
