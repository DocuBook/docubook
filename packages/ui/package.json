{
  "name": "@docubook/ui",
  "version": "0.1.0",
  "description": "React + DaisyUI component library for documentation sites",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./cn": {
      "import": {
        "types": "./dist/cn.d.ts",
        "default": "./dist/cn.js"
      },
      "require": {
        "types": "./dist/cn.d.cts",
        "default": "./dist/cn.cjs"
      }
    },
    "./input": {
      "import": {
        "types": "./dist/input/index.d.ts",
        "default": "./dist/input/index.js"
      },
      "require": {
        "types": "./dist/input/index.d.cts",
        "default": "./dist/input/index.cjs"
      }
    },
    "./kbd": {
      "import": {
        "types": "./dist/kbd/index.d.ts",
        "default": "./dist/kbd/index.js"
      },
      "require": {
        "types": "./dist/kbd/index.d.cts",
        "default": "./dist/kbd/index.cjs"
      }
    },
    "./toggle": {
      "import": {
        "types": "./dist/toggle/index.d.ts",
        "default": "./dist/toggle/index.js"
      },
      "require": {
        "types": "./dist/toggle/index.d.cts",
        "default": "./dist/toggle/index.cjs"
      }
    },
    "./dropdown": {
      "import": {
        "types": "./dist/dropdown/index.d.ts",
        "default": "./dist/dropdown/index.js"
      },
      "require": {
        "types": "./dist/dropdown/index.d.cts",
        "default": "./dist/dropdown/index.cjs"
      }
    },
    "./modal": {
      "import": {
        "types": "./dist/modal/index.d.ts",
        "default": "./dist/modal/index.js"
      },
      "require": {
        "types": "./dist/modal/index.d.cts",
        "default": "./dist/modal/index.cjs"
      }
    },
    "./drawer": {
      "import": {
        "types": "./dist/drawer/index.d.ts",
        "default": "./dist/drawer/index.js"
      },
      "require": {
        "types": "./dist/drawer/index.d.cts",
        "default": "./dist/drawer/index.cjs"
      }
    },
    "./collapse": {
      "import": {
        "types": "./dist/collapse/index.d.ts",
        "default": "./dist/collapse/index.js"
      },
      "require": {
        "types": "./dist/collapse/index.d.cts",
        "default": "./dist/collapse/index.cjs"
      }
    },
    "./theme-controller": {
      "import": {
        "types": "./dist/theme-controller/index.d.ts",
        "default": "./dist/theme-controller/index.js"
      },
      "require": {
        "types": "./dist/theme-controller/index.d.cts",
        "default": "./dist/theme-controller/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "tailwindcss": ">=4.0.0",
    "daisyui": ">=5.0.0 <6.0.0",
    "lucide-react": ">=1.0.0"
  },
  "peerDependenciesMeta": {
    "lucide-react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.0",
    "@types/react": "^19.2.0",
    "jsdom": "^26.1.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.6"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/docubook/frameworks",
    "directory": "packages/ui"
  }
}
