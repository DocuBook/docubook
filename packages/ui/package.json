{
  "name": "@docubook/ui",
  "version": "0.1.0",
  "description": "React UI base components for the DocuBook ecosystem",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./utils": {
      "types": "./dist/utils/index.d.ts",
      "import": "./dist/utils/index.js",
      "default": "./dist/utils/index.js"
    },
    "./base": {
      "types": "./dist/base/index.d.ts",
      "import": "./dist/base/index.js",
      "default": "./dist/base/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rm -rf dist tsconfig.tsbuildinfo && tsc -p tsconfig.json",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "pnpm run clean && pnpm run build"
  },
  "keywords": [
    "docubook",
    "react",
    "ui",
    "components",
    "base-ui",
    "tailwind"
  ],
  "homepage": "https://docubook.pro/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DocuBook/docubook.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "author": "wildan.nrs",
  "author-url": "https://wildan.dev",
  "license": "MIT",
  "peerDependencies": {
    "lucide-react": "^1.7.0",
    "react": ">=18",
    "react-dom": ">=18"
  },
  "peerDependenciesMeta": {
    "lucide-react": {
      "optional": true
    }
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "sonner": "^1.7.4",
    "tailwind-merge": "^2.6.1"
  },
  "devDependencies": {
    "@types/react": "19.2.8",
    "@types/react-dom": "19.2.3",
    "lucide-react": "^1.7.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "typescript": "^5.9.3"
  }
}
