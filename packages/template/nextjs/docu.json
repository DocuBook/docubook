        "url": "https://www.facebook.com/wildan.nrsh"
      },
      {
        "name": "Twitter",
        "url": "https://x.com/wildan_nrss"
      },
      {
        "name": "Youtube",
        "url": "https://www.youtube.com/@wildan.nrs_"
      }
    ]
  },
