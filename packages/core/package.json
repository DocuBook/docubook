{
    "name": "@docubook/core",
    "version": "1.1.1",
    "description": "Shared MDX compile pipeline and markdown utilities for DocuBook",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "default": "./dist/index.js"
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsc -p tsconfig.json",
        "clean": "rm -rf dist",
        "prepublishOnly": "pnpm run clean && pnpm run build"
    },
    "keywords": [
        "docubook",
        "documentation",
        "docs framework",
        "mdx compile",
        "markdown utilities"
    ],
    "homepage": "https://docubook.pro/",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/DocuBook/docubook"
    },
    "author": "wildan.nrs",
    "author-url": "https://wildan.dev",
    "license": "MIT",
    "dependencies": {
        "gray-matter": "^4.0.3",
        "next-mdx-remote": "^6.0.0",
        "rehype-autolink-headings": "^7.1.0",
        "rehype-code-titles": "^1.2.1",
        "rehype-prism-plus": "^2.0.2",
        "rehype-slug": "^6.0.0",
        "remark-gfm": "^4.0.1",
        "unist-util-visit": "^5.1.0"
    },
    "devDependencies": {
        "@types/node": "^20.19.37",
        "@types/react": "19.2.8",
        "@types/unist": "^3.0.3",
        "typescript": "^5.9.3"
    }
}