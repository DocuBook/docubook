{
  "name": "@docubook/core",
  "version": "1.8.2",
  "description": "Shared MDX compile pipeline and markdown utilities for DocuBook",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./utils": {
      "types": "./dist/utils.d.ts",
      "import": "./dist/utils.js",
      "default": "./dist/utils.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm run clean && pnpm run build"
  },
  "keywords": [
    "docubook",
    "documentation",
    "docs framework",
    "mdx compile",
    "markdown utilities"
  ],
  "homepage": "https://docubook.pro/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DocuBook/docubook.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "author": "wildan.nrs",
  "author-url": "https://wildan.dev",
  "license": "MIT",
  "dependencies": {
    "@11ty/gray-matter": "^2.1.0",
    "clsx": "^2.1.1",
    "@docubook/mdx-remote": "workspace:^",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-code-titles": "^1.2.1",
    "rehype-prism-plus": "^2.0.2",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.6.0",
    "unist-util-visit": "^5.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.37",
    "@types/react": "19.2.17",
    "@types/unist": "^3.0.3",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "unified": "^11.0.0"
  }
}
