{
  "name": "@docubook/monorepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo build",
    "dev:web": "turbo dev --filter=@docubook/web",
    "dev:next:docker": "turbo dev --filter=docubook-next-docker",
    "dev:next:vercel": "turbo dev --filter=docubook-next",
    "lint": "turbo lint",
    "lint:fix": "turbo lint:fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,mdx,css}\" --ignore-path .gitignore",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,mdx,css}\" --ignore-path .gitignore",
    "clean": "turbo clean",
    "typecheck": "turbo typecheck",
    "release:notes": "node packages/scripts/cli-release.mjs"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "eslint": "^9.39.4",
    "prettier": "^3.8.1",
    "turbo": "^2.8.21",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.2"
  },
  "dependencies": {
    "next": "^16.2.1"
  },
  "engines": {
    "bun": ">=1"
  },
  "packageManager": "bun@1.3.11",
  "bun": {
    "overrides": {
      "flatted": ">=3.4.2"
    }
  }
}